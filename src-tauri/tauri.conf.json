{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anon Music",
  "version": "0.4.6",
  "identifier": "li.saki.anonmusic",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Anon Music",
        "url": "https://music.example.com/music",
        "width": 1180,
        "height": 760,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
